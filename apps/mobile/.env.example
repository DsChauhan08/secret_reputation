# WebSocket URL — set this after deploying the worker
# For local dev with wrangler dev:
EXPO_PUBLIC_WS_URL=ws://YOUR_LOCAL_IP:8787

# For production (after wrangler deploy):
# EXPO_PUBLIC_WS_URL=wss://secret-reputation.YOUR_SUBDOMAIN.workers.dev

# PostHog (from your project settings)
# EXPO_PUBLIC_POSTHOG_KEY=phc_xxx
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional app environment tag (development|staging|production)
# EXPO_PUBLIC_APP_ENV=development
